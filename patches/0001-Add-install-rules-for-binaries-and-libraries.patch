Subject: [PATCH] Add install() rules for binaries and libraries

Add CMake install() commands to install the mcpelauncher-server binary
to bin/ and shared libraries to lib/ under the install prefix.
---
 CMakeLists.txt | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 9682fda..96659c0 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -51,3 +51,6 @@ add_subdirectory(mcpelauncher-core)
 add_subdirectory(android-support-headers)
 add_subdirectory(mcpelauncher-server)
 
+install(TARGETS mcpelauncher-server RUNTIME DESTINATION bin)
+
