From 88579b448f3d23eee2cd71890ec10984c6f04916 Mon Sep 17 00:00:00 2001
From: root
 <root@runnervm5mmn9.f4gzbl3y3u1eff0aeziqr4glla.cx.internal.cloudapp.net>
Date: Wed, 8 Jul 2026 21:01:02 +0000
Subject: [PATCH] fix: use /dev/urandom instead of SYS_getrandom for glibc <
 2.25

---
 src/common.cpp | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git libc-shim/src/common.cpp libc-shim/src/common.cpp
index 2ef6d95..c11c604 100644
--- libc-shim/src/common.cpp
+++ libc-shim/src/common.cpp
@@ -440,7 +440,11 @@ int shim::gettid() {
 
 ssize_t shim::getrandom(void *buf, size_t len, unsigned int flags) {
 #ifdef __linux__
-        return (ssize_t)syscall(SYS_getrandom, buf, len, flags);
+        int fd = ::open("/dev/urandom", 0);
+        if (fd < 0) return -1;
+        ssize_t ret = read(fd, buf, len);
+        close(fd);
+        return ret;
 #elif defined(_WIN32)
         // TODO Implement if needed
         // this insecure stub works for Minecraft
