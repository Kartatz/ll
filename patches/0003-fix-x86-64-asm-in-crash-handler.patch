From: opencode <opencode@example.com>
Date: Fri Jul 3 04:00:00 2026
Subject: [PATCH 3/5] Fix x86_64 and ARM inline asm in crash handler

Replace ARM64-only x29/x30 register references with architecture-
specific equivalents for x86_64 (rbp) and ARM (r11/lr).

diff --git a/mcpelauncher-server/src/crash_handler.cpp b/mcpelauncher-server/src/crash_handler.cpp
index 60f4d5f..10d3b9e 100644
--- a/mcpelauncher-server/src/crash_handler.cpp
+++ b/mcpelauncher-server/src/crash_handler.cpp
@@ -104,7 +104,13 @@ void _handleSignal(int signal, void *aptr) {
     }
     uint64_t fpval;
     uint64_t retval;
+#if defined(__aarch64__)
     asm("mov %0, x29\nmov %1, x30":"=r"(fpval),"=r"(retval));
+#elif defined(__arm__)
+    asm("mov %0, r11\nmov %1, lr":"=r"(fpval),"=r"(retval));
+#elif defined(__x86_64__)
+    asm("mov %%rbp, %0\nmov 8(%%rbp), %1":"=r"(fpval),"=r"(retval));
+#else
+    fpval = 0; retval = 0;
+#endif
     printf("Calling stack:\n");
     while(1) {
 	    Dl_info symInfo;
